{
  "name": "biblequiz-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "dev:local": "vite --mode development --host",
    "dev:network": "vite --mode development --host 0.0.0.0",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "preview:dev": "vite preview --mode development",
    "lint": "echo 'Linting not configured yet'",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/e2e.mjs local",
    "test:e2e:dev": "node scripts/e2e.mjs dev",
    "test:e2e:prod": "node scripts/e2e.mjs prod --grep @smoke",
    "test:e2e:headed": "node scripts/e2e.mjs local --headed",
    "test:e2e:report": "playwright show-report playwright-report/local",
    "test:e2e:report:dev": "playwright show-report playwright-report/dev",
    "test:e2e:report:prod": "playwright show-report playwright-report/prod",
    "validate:i18n": "node scripts/validate-i18n.mjs"
  },
  "dependencies": {
    "@stomp/stompjs": "^7.0.0",
    "@tanstack/react-query": "^5.56.2",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.23.0",
    "sockjs-client": "^1.6.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.67",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.16",
    "happy-dom": "^20.8.9",
    "jsdom": "^27.0.1",
    "postcss": "^8.4.32",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^4.1.2"
  }
}
