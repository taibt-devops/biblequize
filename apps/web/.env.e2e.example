# Playwright per-environment config template.
# Copy to .env.e2e.<env> (e.g., .env.e2e.local, .env.e2e.dev, .env.e2e.prod).
# All .env.e2e.* files are gitignored — except this .example template.
#
# How it loads:
#   1. node scripts/e2e.mjs <env>   → sets E2E_ENV=<env>
#   2. playwright.config.ts auto-loads .env.e2e.<env> first, then .env.e2e (fallback)
#   3. Existing process.env values (CLI) override file values
#
# npm scripts:
#   npm run test:e2e           → E2E_ENV=local
#   npm run test:e2e:dev       → E2E_ENV=dev
#   npm run test:e2e:prod      → E2E_ENV=prod (smoke only)
#   npm run test:e2e:headed    → E2E_ENV=local + --headed

# Target URL — Playwright config auto-disables webServer when not localhost:5173
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Backend URL for direct API calls in fixtures (login, seed-points, etc).
# REQUIRED for local dev: without this the fallback .env.e2e (production)
# loads PLAYWRIGHT_API_URL=https://be.quize.top, which scopes the auth
# cookie to the wrong domain and every smoke test redirects to /login.
PLAYWRIGHT_API_URL=http://localhost:8080

# Test credentials (NEVER commit real values)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Optional: filter tests (used by --grep / --grep-invert)
# PLAYWRIGHT_GREP=@smoke
